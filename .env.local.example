# --- Вход по коду из Telegram (см. README, раздел "Вход по коду из Telegram") ---
# Токен бота из @BotFather (Telegram → найти @BotFather → /mybots → выбрать бота → API Token).
# ВАЖНО: без префикса NEXT_PUBLIC_ — эта переменная остаётся только на сервере, не идёт в браузер.
TELEGRAM_BOT_TOKEN=8148902131:AAFF-tzLgDPj56EPliaYfyeiPnLueqeT_xE

# Необязательно, но рекомендуется: произвольная строка-секрет, чтобы вебхук принимал запросы только от Telegram.
TELEGRAM_WEBHOOK_SECRET=

# Telegram chat_id администратора (числовой), куда бот шлёт уведомления о жалобах на сделки,
# заявках на пополнение/вывод и запросах на сотрудничество. Это ЛИЧНЫЙ chat_id в Telegram, не UID сайта.
TELEGRAM_ADMIN_CHAT_ID=7040863301

# Ссылка на Telegram-канал, который бот предлагает подписать пользователям (необязательно)
NEXT_PUBLIC_TELEGRAM_CHANNEL_URL=

