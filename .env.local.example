# Vercel Blob — хранилище для загрузки фото (замена Firebase Storage, не требует платного тарифа).
# На самом Vercel эта переменная подставляется автоматически, когда в проекте подключено Blob-хранилище
# (Vercel Dashboard → твой проект → Storage → Create Database → Blob). Для запуска на localhost
# нужно скопировать значение вручную: Vercel Dashboard → Storage → твоё Blob-хранилище → .env.local,
# либо выполнить `vercel env pull .env.local`, если установлен Vercel CLI.
BLOB_READ_WRITE_TOKEN=

